-- 🚀 Core Automation Logic Handler
processCurrentWord = function(rawWord)
    if not rawWord or rawWord == "" then return end
    
    lastReceivedWord = rawWord
    WordLabel:Set("📝 Raw Word: " .. rawWord)
    LengthLabel:Set("📏 Length: " .. string.len(rawWord) .. " characters")
    
    currentSessionID = currentSessionID + 1
    local mySessionID = currentSessionID
    
    -- ✅ Ownership check removed – always allowed
    -- if not isTargetOwner then
    --     StatusLabel:Set("⛔ Status: Blocked (Unauthorized User)")
    --     return
    -- end

    local textBox = getTargetTextBox()
    if not textBox then
        StatusLabel:Set("⏳ Status: Blocked (Waiting for Active TextBox)")
        return
    end

    task.spawn(function()
        if CopyNPasteEnabled then
            if setclipboard then setclipboard(rawWord)
            elseif toclipboard then toclipboard(rawWord) end
        end
        
        if AutoTypeEnabled then
            StatusLabel:Set("⚡ Status: Outputting String Data...")
            textBox.Text = ""
            textBox:CaptureFocus()
            
            local delayTime = 1 / math.max(1, AutoTypeCPS)
            if WPMToggleEnabled then
                delayTime = 60 / (AutoTypeWPM * 5)
            end
            
            for i = 1, #rawWord do
                if not AutoTypeEnabled or currentSessionID ~= mySessionID or not textBox.Visible or textBox.AbsoluteSize.Y <= 5 then 
                    break 
                end
                textBox.Text = string.sub(rawWord, 1, i)
                task.wait(delayTime)
            end
            
            -- 🔥 ENTER KEY SUBMISSION KEYSTROKE
            if currentSessionID == mySessionID and textBox.Visible and textBox.AbsoluteSize.Y > 5 then
                task.wait(0.04) 
                local vim = game:GetService("VirtualInputManager")
                if vim then
                    if not textBox:IsFocused() then textBox:CaptureFocus() end
                    vim:SendKeyEvent(true, Enum.KeyCode.Return, false, game)
                    task.wait(0.01)
                    vim:SendKeyEvent(false, Enum.KeyCode.Return, false, game)
                else
                    textBox:ReleaseFocus(true)
                end
                StatusLabel:Set("🔵 Status: Idle")
            end
        else
            StatusLabel:Set("🔵 Status: Idle")
        end
    end)
end

-- ⚡ Continuous Tracking and Dynamic Hook Verification Loop
task.spawn(function()
    local lastBoxState = false
    while true do
        -- Ownership check removed – always true
        isTargetOwner = true
        
        -- Update user verification interface label
        UserCheckLabel:Set("👤 User Allowed to Type: ✅ YES (" .. localPlayer.Name .. ")")
        
        -- Dynamic word validation updates 
        if not wordValueInstance or not wordValueInstance.Parent then
            local checkNested = replicatedStorage:FindFirstChild("ReplicatedStorage")
            if checkNested then
                wordValueInstance = checkNested:FindFirstChild("replayWord")
            else
                wordValueInstance = replicatedStorage:FindFirstChild("replayWord")
            end
        end

        if wordValueInstance then
            ValueFoundLabel:Set("✅ replayWord Found: YES")
        else
            ValueFoundLabel:Set("❌ replayWord Found: NO (Scanning runtime memory...)")
        end
        
        -- TextBox loop verification and string output updates
        local currentTextBox = getTargetTextBox()
        local boxStateNow = (currentTextBox ~= nil)
        
        if boxStateNow ~= lastBoxState then
            lastBoxState = boxStateNow
            if boxStateNow and wordValueInstance and wordValueInstance.Value ~= "" then
                processCurrentWord(wordValueInstance.Value)
            end
        end
        
        -- Run an immediate processing scan if value updates
        if wordValueInstance and wordValueInstance.Value ~= lastReceivedWord then
            processCurrentWord(wordValueInstance.Value)
        end
        
        task.wait(0.1) 
    end
end)

