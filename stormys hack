-- 🎯 TextBox Target Retriever (PlayerGui -> ScreenGui -> typeFrame -> typeBox)
local function getTargetTextBox()
    if not localPlayer then return nil end
    local playerGui = localPlayer:FindFirstChild("PlayerGui")
    if not playerGui then return nil end
    
    local screenGui = playerGui:FindFirstChild("ScreenGui")
    if screenGui and screenGui:IsA("ScreenGui") then
        local typeFrame = screenGui:FindFirstChild("typeFrame")
        if typeFrame and typeFrame:IsA("Frame") then
            local typeBox = typeFrame:FindFirstChild("typeBox")
            
            if typeBox and typeBox:IsA("TextBox") then
                -- 🛡️ Visibility and absolute geometry constraints
                local isFullyVisible = screenGui.Enabled and typeFrame.Visible and typeBox.Visible 
                local hasPhysicalSize = typeBox.AbsoluteSize.X > 5 and typeBox.AbsoluteSize.Y > 5
                
                if isFullyVisible and hasPhysicalSize then
                    TextBoxFoundLabel:Set("✅ TextBox Active & Accessible: YES")
                    return typeBox
                else
                    TextBoxFoundLabel:Set("⏳ TextBox Status: Hidden, Scaling, or Disabled Frame")
                    return nil
                end
            end
        end
    end
    
    TextBoxFoundLabel:Set("❌ TextBox Present on Screen: NO (Path Not Found)")
    return nil
end

